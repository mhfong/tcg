# TCG Pro — environment variables
#
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# Only variables prefixed with `VITE_` are visible to the frontend.

# ----- Supabase (required) -----
# Get these from your Supabase project settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ----- yuyu-tei parse proxy (optional) -----
# The "Import from yuyu-tei" feature calls this URL to fetch set pages.
#
# Yuyu-tei returns 403 to most cloud-provider IPs, so the deployed site
# can't talk to yuyu-tei directly. We run a tiny proxy (scripts/parse_server.py)
# that does the fetching on our behalf.
#
# Two options:
#
#   (a) Local dev — run `python3 scripts/parse_server.py` on the same
#       machine as your browser. Default below; do not change for local dev.
#
#   (b) Public deploy — point at a publicly reachable proxy. See
#       scripts/PROXY_DEPLOY.md for Fly.io / Render / VPS instructions.
#       Example after Fly.io deploy:
#         VITE_YUYUTEI_PARSE_URL=https://yuyutei-parse.fly.dev/parse
#
VITE_YUYUTEI_PARSE_URL=http://127.0.0.1:8787/parse

# ----- Auth bypass (DEV ONLY) -----
# Set to true ONLY when you want to bypass Supabase auth in local dev.
# Note: bypassing auth still causes 401s on row-level queries because the
# fake user doesn't exist in auth.users. Set to false (or remove) once the
# real auth is working in your browser — sign in via the Login page.
VITE_PREVIEW_AUTH_BYPASS=false

# ----- Local-only credentials (NEVER commit a real .env) -----
# Used by scripts/ to sign in during local dev. These are NOT loaded by
# the frontend; they live in `.env` purely for your convenience.
login_username=your-email@example.com
login_password=your-password

# Supabase access token (for `supabase db query` etc.). Server-side only.
SUPABASE_ACCESS_TOKEN=

# OpenRouter API key (used by the OpenRouter quota footer in Copilot).
api_key=
